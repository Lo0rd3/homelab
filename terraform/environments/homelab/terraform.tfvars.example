proxmox_endpoint = "https://pve.example.internal:8006/"
proxmox_insecure = true

target_node_name = "prox"

vms = {
  monitoring = {
    guest_name              = "monitoring-01"
    clone_source_vm_id      = 9001
    disk_datastore_id       = "local-lvm"
    bridge                  = "vmbr0"
    cpu_cores               = 2
    memory_mb               = 4096
    disk_size_gb            = 32
    full_clone              = true
    network_model           = "virtio"
    network_vlan_tag        = 20
    cloud_init_datastore_id = "local"
    user_name               = "debian"
    ssh_public_keys = [
      "ssh-ed25519 replace-me"
    ]
    ipv4_address = "dhcp"
    ipv4_gateway = null
  }
}

lxcs = {
  tailscale = {
    vm_id            = 201
    hostname         = "tailscale-01"
    template_file_id = "local:vztmpl/debian-12-standard_12.7-1_amd64.tar.zst"
    disk_datastore_id = "local"
    bridge           = "vmbr0"
    cpu_cores        = 1
    memory_mb        = 1024
    swap_mb          = 256
    disk_size_gb     = 6
    ipv4_address     = "192.168.1.2/24"
    ipv4_gateway     = "192.168.1.254"
    dns_servers      = ["192.168.1.252"]
    ssh_public_keys = [
      "ssh-ed25519 replace-me"
    ]
    description = "Tailscale subnet router and exit node"
    tags        = ["tailscale", "router", "remote-access"]
    os_type     = "debian"
  }

  adguard = {
    vm_id            = 202
    hostname         = "adguard-01"
    template_file_id = "local:vztmpl/alpine-3.23-default_20260116_amd64.tar.xz"
    disk_datastore_id = "local"
    bridge           = "vmbr0"
    cpu_cores        = 1
    memory_mb        = 512
    swap_mb          = 512
    disk_size_gb     = 6
    ipv4_address     = "192.168.1.252/24"
    ipv4_gateway     = "192.168.1.254"
    dns_servers      = ["212.55.154.174"]
    ssh_public_keys = [
      "ssh-ed25519 replace-me"
    ]
    description = "AdGuard Home instance"
    tags        = ["adguard", "dns", "dhcp"]
    os_type     = "alpine"
  }
}

# Export credentials instead of committing them:
#   export PROXMOX_VE_API_TOKEN="set-this-in-your-shell"
