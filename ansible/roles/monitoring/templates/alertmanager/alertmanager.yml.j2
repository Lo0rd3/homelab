---
# Starter Alertmanager config.
# Replace the default webhook URL from vaulted vars or a runtime secret file before using real notifications.
global:
  resolve_timeout: {{ monitoring_alertmanager_resolve_timeout | default('5m') }}

route:
  receiver: {{ monitoring_alertmanager_default_receiver_name | default('default-webhook') | to_json }}
  group_by:
    - alertname
    - job
    - instance
  group_wait: {{ monitoring_alertmanager_group_wait | default('30s') }}
  group_interval: {{ monitoring_alertmanager_group_interval | default('5m') }}
  repeat_interval: {{ monitoring_alertmanager_repeat_interval | default('4h') }}

receivers:
  - name: {{ monitoring_alertmanager_default_receiver_name | default('default-webhook') | to_json }}
    webhook_configs:
      - url: {{ monitoring_alertmanager_default_webhook_url | default('http://alertmanager-webhook-placeholder.local/') | to_json }}
        send_resolved: true
